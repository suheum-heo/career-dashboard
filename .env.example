# Neon (recommended) — https://console.neon.tech
# Dashboard → Connection details → copy both URLs
# Use the pooled connection for DATABASE_URL (ends with -pooler)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Local Docker Postgres (optional fallback)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/career_dashboard?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/career_dashboard?schema=public"
